{
  "colors": {
    "background": "#1a1a1f",
    "border": "#1d1d22",
    "textPrimary": "#ededf0",
    "textMuted": "#8a8a94",
    "textSubtle": "#5a5a64",
    "bullet": "#5a5a64"
  },
  "spacing": { "paddingX": 16, "paddingY": 16, "columnGap": 24, "itemGap": 8 },
  "typography": {
    "section": { "size": 12, "weight": 500, "transform": "uppercase", "tracking": "0.05em" },
    "item": { "size": 14, "weight": 400 }
  },
  "grid": "1fr 220px"
}
