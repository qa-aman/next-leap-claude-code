{
  "color": {
    "text-default": { "value": "#020817", "source": "computed:body" },
    "text-heading": { "value": "#111827", "source": "computed:h3,h4,blockquote" },
    "text-body": { "value": "#293142", "source": "computed:article p" },
    "text-muted": { "value": "#696969", "source": "computed:footer a" },
    "text-footer-heading": { "value": "#1C1C1C", "source": "computed:footer h3" },
    "text-h1": { "value": "#000000", "source": "computed:h1" },
    "link": { "value": "#7293F3", "source": "computed:article a" },
    "bg-page": { "value": "#FFFFFF", "source": "computed:body" },
    "bg-footer": { "value": "#F8F8F8", "source": "computed:footer" },
    "brand-red": { "value": "#CB202D", "source": "zomato brand" },
    "border-muted": { "value": "#E5E7EB", "source": "tailwind gray-200 used in card dividers" },
    "text-secondary": { "value": "#828282", "source": "computed:breadcrumb a (Phase 02)" },
    "text-card-title": { "value": "#1C1C1C", "source": "computed:listing card h4 (Phase 02)" },
    "rating-green": { "value": "#3F7E00", "source": "Zomato rating chip >=4.0 (Phase 02, observed)" },
    "rating-yellow": { "value": "#9C7E00", "source": "Zomato rating chip 3.0-3.9 (Phase 02, observed)" },
    "rating-red": { "value": "#CB202D", "source": "aliased to brand-red for <3.0 (Phase 02)" },
    "border-pill": { "value": "#E8E8E8", "source": "filter pill border (Phase 02)" },
    "bg-promoted": { "value": "rgba(0,0,0,0.3)", "source": "computed:listing card promoted badge (Phase 02)" },
    "white": { "value": "#FFFFFF", "source": "literal, used inside rating-chip, restaurant-card overlay, collection-card overlay" }
  },
  "typography": {
    "family-article": { "value": "\"Be Vietnam Pro\", sans-serif", "source": "computed:article *" },
    "family-footer":  { "value": "Okra, sans-serif", "source": "computed:footer" },
    "family-system":  { "value": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif", "source": "computed:body" },

    "size-h1":   { "value": "60px",   "lineHeight": "72px",   "weight": 500, "source": "computed:h1" },
    "size-h2":   { "value": "36px",   "lineHeight": "44px",   "weight": 600, "source": "scale step between h1 and h3" },
    "size-h3":   { "value": "24px",   "lineHeight": "32px",   "weight": 600, "source": "computed:h3" },
    "size-h4":   { "value": "20px",   "lineHeight": "28px",   "weight": 600, "source": "computed:h4" },
    "size-body": { "value": "20px",   "lineHeight": "32.5px", "weight": 300, "source": "computed:article p" },
    "size-blockquote": { "value": "18px", "lineHeight": "32px", "weight": 500, "source": "computed:blockquote" },
    "size-meta": { "value": "14px",   "lineHeight": "20px",   "weight": 300, "source": "computed:footer a" },
    "size-footer-h3": { "value": "14px", "lineHeight": "20px", "weight": 500, "letterSpacing": "2px", "transform": "uppercase", "source": "computed:footer h3" },
    "size-copy": { "value": "13px",   "lineHeight": "21.125px", "weight": 300, "source": "computed:footer p" },
    "size-tag":  { "value": "12px",   "lineHeight": "16px",   "weight": 500, "letterSpacing": "1px", "transform": "uppercase", "source": "computed:article category tag" },
    "size-card-title": { "value": "17px", "lineHeight": "20.4px", "weight": 500, "source": "computed:listing card h4 (Phase 02)" },
    "size-card-meta":  { "value": "14px", "lineHeight": "21px",   "weight": 300, "source": "computed:listing card p (Phase 02)" },
    "size-pill":       { "value": "14px", "lineHeight": "20px",   "weight": 400, "source": "filter pill (Phase 02)" }
  },
  "spacing": {
    "0":  { "value": "0px",   "source": "computed" },
    "1":  { "value": "4px",   "source": "scale" },
    "2":  { "value": "8px",   "source": "computed:h4 margin-bottom" },
    "3":  { "value": "12px",  "source": "computed:h3 margin-bottom" },
    "4":  { "value": "16px",  "source": "computed:h4 margin-top" },
    "5":  { "value": "24px",  "source": "computed:h3 margin-top" },
    "6":  { "value": "32px",  "source": "computed:h1 margin-bottom, p margin-bottom" },
    "7":  { "value": "40px",  "source": "computed:blockquote padding-left" },
    "8":  { "value": "64px",  "source": "scale" },
    "9":  { "value": "120px", "source": "computed:main padding-top" }
  },
  "radius": {
    "none": { "value": "0px",  "source": "computed:default" },
    "sm":   { "value": "4px",  "source": "scale" },
    "md":   { "value": "8px",  "source": "scale" },
    "lg":   { "value": "12px", "source": "scale" },
    "full": { "value": "9999px", "source": "tag/pill" },
    "pill": { "value": "2px", "source": "computed:promoted badge (Phase 02)" }
  },
  "shadow": {
    "none": { "value": "none", "source": "computed:default" },
    "sm":   { "value": "0 1px 2px 0 rgba(0,0,0,0.05)",  "source": "tailwind shadow-sm" },
    "md":   { "value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.06)", "source": "tailwind shadow" }
  },
  "breakpoint": {
    "sm": { "value": "640px",  "source": "tailwind sm" },
    "md": { "value": "768px",  "source": "tailwind md" },
    "lg": { "value": "1024px", "source": "tailwind lg" },
    "xl": { "value": "1280px", "source": "tailwind xl" }
  },
  "layout": {
    "article-max-width": { "value": "896px", "source": "computed:article width at 1280px viewport" },
    "header-height":     { "value": "120px", "source": "computed:main padding-top" }
  }
}
